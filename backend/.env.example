# Optional: MySQL (start Docker first: docker compose up -d)
# DATABASE_URL=mysql+pymysql://root:rootsecret@127.0.0.1:3306/indian_algo
#
# If DATABASE_URL is not set, the API uses SQLite at backend/instance/app.db

JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Angel One SmartAPI — Live Market Quote (https://apiconnect.angelone.in/.../market/v1/quote/) ---
# Required for GET /angel/live-quote (after you sign in to the app with /auth/login JWT).
#
# ANGEL_API_KEY        → header X-PrivateKey (your SmartAPI API key)
# ANGEL_JWT_TOKEN     → Authorization: Bearer <jwt> (short-lived; renew with ANGEL_REFRESH_TOKEN below)
# ANGEL_REFRESH_TOKEN → from same login script output; backend renews JWT every 8h and on 403 Token errors
#
# For the login script only (not sent to quote API as body):
# ANGEL_CLIENT_ID=     # Angel login id
# ANGEL_PIN=           # 4-digit MPIN
# ANGEL_TOTP_SECRET=   # Base32 seed (A–Z, 2–7), or otpauth://… URL, or 16+ char hex (rare)
# ANGEL_EXCHANGE_TOKENS → JSON (max 50 tokens per request). SENSEX (BSE index) default:
#   {"BSE":["99919000"]}
# Stock example — SBIN NSE EQ: {"NSE":["3045"]} — search tokens in Angel OpenAPIScripMaster.json
#
ANGEL_API_KEY=yh1ArV5D
ANGEL_CLIENT_ID=VAHL1375
ANGEL_PIN=4321
ANGEL_TOTP_SECRET=JBSWY3DPEHPK3PXP
ANGEL_JWT_TOKEN=
ANGEL_REFRESH_TOKEN=
ANGEL_EXCHANGE_TOKENS={"BSE":["99919000"]}
# LTP | OHLC | FULL
ANGEL_QUOTE_MODE=OHLC
#
# Headers required by Angel (defaults are safe for local dev; use real values if Angel rejects):
ANGEL_SOURCE_ID=WEB
ANGEL_CLIENT_LOCAL_IP=127.0.0.1
ANGEL_CLIENT_PUBLIC_IP=127.0.0.1
ANGEL_MAC_ADDRESS=00:00:00:00:00:00
ANGEL_USER_TYPE=USER
ANGEL_REQUEST_TIMEOUT_SEC=15
# Set true to include full Angel JSON in API response (debug only)
ANGEL_DEBUG=false

# --- LIVE BFO Sensex options (SmartAPI placeOrder) ---
# JSON array: [{"strike":75800,"side":"PE","token":"...","tradingsymbol":"...","lotsize":20}, ...]
# Use Angel master file for the correct weekly expiry tokens/symbols.
ANGEL_BFO_INSTRUMENTS_JSON=
ANGEL_OPTION_EXCHANGE=BFO
ANGEL_OPTION_PRODUCT_TYPE=CARRYFORWARD
DEFAULT_SENSEX_OPTION_LOT_SIZE=20
